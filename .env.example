# LLM provider API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default models
# HUB_VS_SPOKE_DEFAULT_HUB_MODEL=claude-sonnet-4-20250514
# HUB_VS_SPOKE_DEFAULT_SPOKE_MODEL=gpt-4o-mini

# Optional: token budget per topology run
# HUB_VS_SPOKE_TOKEN_BUDGET=50000

# Optional: number of repetitions per configuration
# HUB_VS_SPOKE_REPETITIONS=3
